<%= tag.link rel: "stylesheet", href: "/lexxy.css" %>

<div class="demo">
  <header>
    <h1>yrby collaborative editor <small>(Lexxy)</small></h1>
    <%= render "nav" %>
    <p>
      Document <code><%= @document_id %></code> —
      open this page in another window to edit together. Same document and server
      as the <a href="<%= document_path(@document_id) %>">Tiptap editor</a>; only
      the front end differs.
      <a href="<%= document_content_path(@document_id) %>" target="_blank">
        View server-side state</a> (the raw CRDT, base64, read in Ruby with no JS).
    </p>
    <p id="status" class="status">connecting…</p>
  </header>

  <%# data-direct-upload-url / data-blob-url-template: the Trix-convention
      attributes both Lexxy and Rhino read for ActiveStorage direct uploads.
      Uploads go straight to ActiveStorage; the editor inserts an attachment
      node (sgid + URL) into the shared doc, and peers render it from the
      URL like any other content. %>
  <lexxy-editor id="editor" name="editor" data-document-id="<%= @document_id %>"
                data-direct-upload-url="<%= rails_direct_uploads_url %>"
                data-blob-url-template="<%= rails_service_blob_url(":signed_id", ":filename") %>"></lexxy-editor>

  <%= render "materialized_note", note: @note, renderer: "Y::Lexxy" %>
</div>

<script src="/lexxy.js" defer></script>
