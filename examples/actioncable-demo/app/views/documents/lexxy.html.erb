<%= tag.link rel: "stylesheet", href: "/lexxy.css" %>

<div class="demo">
  <header>
    <h1>yrby collaborative editor <small>(Lexxy)</small></h1>
    <%= render "nav" %>
    <p>
      Document <code><%= @document_id %></code> —
      open this page in another window to edit together. Same document and server
      as the <a href="<%= document_path(@document_id) %>">Tiptap editor</a>; only
      the front end differs.
      <a href="<%= document_content_path(@document_id) %>" target="_blank">
        View server-side state</a> (the raw CRDT, base64, read in Ruby with no JS).
    </p>
    <p id="status" class="status">connecting…</p>
  </header>

  <lexxy-editor id="editor" name="editor" data-document-id="<%= @document_id %>"></lexxy-editor>

  <%= render "materialized_note", note: @note, renderer: "Y::Lexxy" %>
</div>

<script src="/lexxy.js" defer></script>
