<%= tag.link rel: "stylesheet", href: "/rhino.css" %>
<style>
  /* CollaborationCaret's remote carets, styled like the Tiptap page's cursors. */
  .collaboration-carets__caret {
    position: relative;
    border-left: 2px solid;
    margin-left: -1px;
    margin-right: -1px;
    word-break: normal;
    pointer-events: none;
  }
  .collaboration-carets__label {
    position: absolute;
    top: -1.3em;
    left: -2px;
    font-size: 12px;
    color: white;
    padding: 0 4px;
    border-radius: 3px 3px 3px 0;
    white-space: nowrap;
    user-select: none;
  }
</style>

<div class="demo">
  <header>
    <h1>yrby collaborative editor <small>(Rhino)</small></h1>
    <%= render "nav" %>
    <p>
      Document <code><%= @document_id %></code> —
      open this page in another window to edit together. Same document and
      server as the <a href="<%= document_path(@document_id) %>">Tiptap</a> and
      <a href="<%= document_lexxy_path(@document_id) %>">Lexxy</a> editors; this
      one is <a href="https://github.com/KonnorRogers/rhino-editor">Rhino</a>
      (Tiptap 3), bound the way a real app would: Tiptap's own Collaboration
      extensions, configured before the editor initializes.
      <a href="<%= document_content_path(@document_id) %>" target="_blank">
        View server-side state</a> (the raw CRDT, base64, read in Ruby with no JS).
    </p>
    <p id="status" class="status">connecting…</p>
  </header>

  <rhino-editor id="editor" defer-initialize data-document-id="<%= @document_id %>"></rhino-editor>

  <section class="actiontext-save" style="margin-top:1rem">
    <%# The Note below is a derived view of the collaborative document for
        the rest of the app (search, mailers, plain views). The live
        document is already durable; the note is a cache over the store,
        refreshed on read. Loading this page re-renders it server-side with
        Y::Tiptap when the store has changes the note hasn't seen. No
        editor HTML crosses the wire; the content comes from the
        authoritative CRDT, not from a browser.

        Reading it is stock ActionText: `@note.content` renders through the
        ActionText layout partial and sanitizer like any Rails app. The
        write path is not stock: a normal Rhino app is a Trix replacement
        where a rich_text_area posts the browser's HTML on submit, and a
        collaborative document can't trust a submitting browser. %>
    <% if @note %>
      <h2 style="margin-top:1rem">Materialized ActionText content</h2>
      <p style="color:#666;font-size:.85rem">
        <code>Note#content</code> (an <code>ActionText::RichText</code>),
        rendered by Rails. Refreshed on read; currently through store
        version <%= @note.through_version %>. Edit above and reload to see
        it update.
      </p>
      <div id="saved-note" style="border:1px solid #ddd;border-radius:6px;padding:.5rem 1rem">
        <%= @note.content %>
      </div>
    <% end %>
  </section>
</div>

<script src="/rhino.js" defer></script>
