<%= tag.link rel: "stylesheet", href: "/rhino.css" %>
<style>
  /* CollaborationCaret's remote carets, styled like the Tiptap page's cursors. */
  .collaboration-carets__caret {
    position: relative;
    border-left: 2px solid;
    margin-left: -1px;
    margin-right: -1px;
    word-break: normal;
    pointer-events: none;
  }
  .collaboration-carets__label {
    position: absolute;
    top: -1.3em;
    left: -2px;
    font-size: 12px;
    color: white;
    padding: 0 4px;
    border-radius: 3px 3px 3px 0;
    white-space: nowrap;
    user-select: none;
  }
</style>

<div class="demo">
  <header>
    <h1>yrby collaborative editor <small>(Rhino)</small></h1>
    <%= render "nav" %>
    <p>
      Document <code><%= @document_id %></code> —
      open this page in another window to edit together. Same document and
      server as the <a href="<%= document_path(@document_id) %>">Tiptap</a> and
      <a href="<%= document_lexxy_path(@document_id) %>">Lexxy</a> editors; this
      one is <a href="https://github.com/KonnorRogers/rhino-editor">Rhino</a>
      (Tiptap 3), bound the way a real app would: Tiptap's own Collaboration
      extensions, configured before the editor initializes.
      <a href="<%= document_content_path(@document_id) %>" target="_blank">
        View server-side state</a> (the raw CRDT, base64, read in Ruby with no JS).
    </p>
    <p id="status" class="status">connecting…</p>
  </header>

  <rhino-editor id="editor" defer-initialize data-document-id="<%= @document_id %>"></rhino-editor>

  <section class="actiontext-save" style="margin-top:1rem">
    <%# The ActionText half of the Rhino story: the save posts NO editor
        HTML — the server replays the durable store into a Y::Doc and renders
        this page's fragment with Y::Tiptap. What persists is derived
        from the authoritative CRDT, not the submitting browser.

        The live document is already durable (every update is recorded before
        it's distributed) — this save MATERIALIZES it as ActionText for the
        rest of the app (search, mailers, plain views). The button is the
        demo's stand-in for whatever trigger your app chooses: a debounced
        on_change, a "publish" action, or a background job run the same
        server-side path with no browser involved at all. %>
    <%= button_to "Save to ActionText (rendered server-side from the CRDT)",
                  document_rhino_save_path(@document_id) %>
    <% if flash[:notice] %><p class="status" data-state="connected"><%= flash[:notice] %></p><% end %>
    <% if flash[:alert] %><p class="status" data-state="error"><%= flash[:alert] %></p><% end %>

    <% if @note %>
      <h2 style="margin-top:1rem">Saved ActionText content</h2>
      <p style="color:#666;font-size:.85rem">
        <code>Note#content</code> (an <code>ActionText::RichText</code>),
        rendered by Rails — saved <%= time_ago_in_words(@note.content.updated_at) %> ago.
      </p>
      <div id="saved-note" style="border:1px solid #ddd;border-radius:6px;padding:.5rem 1rem">
        <%= @note.content %>
      </div>
    <% end %>
  </section>
</div>

<script src="/rhino.js" defer></script>
